# Conexión a PostgreSQL — copiá este archivo a .env y completá la URL.
#
# Neon (recomendado): en el dashboard, sección "Connection string",
# copiá la URL "pooled" (incluye ?sslmode=require) y pegala acá.
DATABASE_URL=postgresql://USUARIO:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require

# Puerto (opcional; los hosts de deploy como Render/Railway lo setean solos)
PORT=3000
